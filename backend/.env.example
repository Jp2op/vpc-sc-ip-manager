# App
IPMGR_DEBUG=true
IPMGR_API_PREFIX=/api/v1

# Auth (leave empty to disable in dev)
IPMGR_API_KEY=

# Storage: "memory" (dev), "firestore" (native), or "mongodb" (Firestore MongoDB-compatible)
IPMGR_STORAGE_BACKEND=memory

# Firestore native (only if storage_backend=firestore)
IPMGR_GCP_PROJECT_ID=project-d10cf6ac-cbee-4322-849
IPMGR_FIRESTORE_COLLECTION=ip_whitelist

# MongoDB / Firestore MongoDB-compatible (only if storage_backend=mongodb)
IPMGR_MONGO_URI=mongodb://user:pass@xxxxx.firestore.goog:443/dbname?loadBalanced=true&tls=true&authMechanism=SCRAM-SHA-256&retryWrites=false
IPMGR_MONGO_DB=ip_manager

# GitHub (leave empty for mock mode)
IPMGR_GITHUB_TOKEN=
IPMGR_GITHUB_REPO=Jp2op/vpc-sc-ip-manager
IPMGR_GITHUB_CONFIG_PATH=access_config.json
IPMGR_GITHUB_BRANCH=main

# Admin IPs (always included in config, comma-separated)
IPMGR_ADMIN_IPS=

# CORS
IPMGR_CORS_ORIGINS=*
